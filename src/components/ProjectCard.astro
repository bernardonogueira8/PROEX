---
const { title, image, objectives, link, description } = Astro.props;

const modalId = `modal_${title.replace(/[^a-zA-Z0-9]/g, "")}`;
---

<!-- 1. CARD PRINCIPAL -->
<div 
  class="card bg-base-100 shadow-sm border border-base-300 hover:border-primary hover:shadow-md transition-all duration-300 cursor-pointer"
  onclick={`document.getElementById('${modalId}').showModal()`}
>
  <div class="relative"> 
    <figure class="px-2 pt-2">
      <img src={image} alt={title} class="rounded-xl aspect-video object-cover image-full brightness-95 hover:brightness-100 transition-all" />
    </figure>

    <div class="card-body p-4">
      <h1 class="card-title text-sm font-bold uppercase tracking-widest text-primary">{title}</h1>
      <div class="mt-2">
        <!-- text-base-content/60 adiciona opacidade à cor de texto padrão para criar um cinza -->
        <p class="text-xs font-semibold text-base-content/60 uppercase tracking-wider">Objetivos e indicadores:</p>
        <p class="text-sm line-clamp-3 mt-1 text-base-content/80">{objectives}</p>
      </div>
    </div>
  </div>
</div>

<!-- 2. MODAL DETALHADO (lg:card-side) -->
<dialog id={modalId} class="modal modal-bottom sm:modal-middle">
  <div class="modal-box p-0 w-11/12 max-w-5xl bg-base-100 border border-base-300 shadow-2xl">
    
    <div class="card lg:card-side bg-transparent rounded-none">
      
      <figure class="lg:w-1/2">
        <img
          src={image}
          alt={title} 
          class="object-cover w-full h-full lg:h-[350px]" 
        />
      </figure>

      <div class="card-body lg:w-1/2">
        
        <div class="flex justify-between items-start gap-4">
          <h2 class="card-title text-2xl font-extrabold uppercase tracking-tight text-secondary">{title}</h2>
        </div>        
        <div class="flex-grow">
          <p class="text-sm font-bold text-base-content/60 uppercase tracking-wider mb-2">Descrição do Indicador:</p>
          <p class="text-base leading-relaxed text-base-content/90">{description}</p>
        </div>
        
        <div class="card-actions justify-end mt-6">
          <a href={link} target="_blank" class="btn btn-primary">
            Acessar Painel
          </a>
          <form method="dialog">
            <!-- btn-outline btn-error cria um botão fantasma com bordas e texto vermelhos -->
            <button class="btn btn-outline btn-error">
              Fechar
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
  
  <form method="dialog" class="modal-backdrop bg-neutral/40 backdrop-blur-sm">
    <button>close</button>
  </form>
</dialog>